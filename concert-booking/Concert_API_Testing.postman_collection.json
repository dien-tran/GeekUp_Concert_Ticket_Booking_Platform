						"body": {
							"mode": "raw",
							"raw": "{\n    \"concertId\": \"{{concertId}}\",\n    \"ticketIds\": [\"{{ticketId}}\"],\n    \"voucherCode\": \"\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/payment/checkout", "host": ["{{baseUrl}}"], "path": ["payment", "checkout"] }
